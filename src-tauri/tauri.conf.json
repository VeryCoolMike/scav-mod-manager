{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scav Mod Manager",
  "version": "0.1.0",
  "identifier": "org.scavprototype.modmanager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Scav Mod Manager",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["nxm"]
      }
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/VeryCoolMike/scav-mod-manager/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUwRDFGM0I3NDRDQzI4OTkKUldTWktNeEV0L1BSVUJ1VDRNL2FISXc1ZG5xMjBERWJiblNEUnVZbndDcitmZURtclhWVllIMlAK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
